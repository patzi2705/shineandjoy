---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Kontakt">
  <section class="contact">
    <h1>Kontakt</h1>

    <p>Schreib uns gerne direkt:</p>

    <div class="buttons">
      <a href="mailto:shineandjoy@gmail.com" class="btn">📧 E-Mail</a>

      <a href="https://wa.me/436645476454" class="btn" target="_blank">
        💬 WhatsApp
      </a>

      <a href="https://www.instagram.com/shineandjoy.bymk/" class="btn" target="_blank">
        📸 Instagram
      </a>
    </div>
  </section>
</MainLayout>

<style>
  .contact {
    text-align: center;
    margin-top: 40px;
  }

  .buttons {
    margin-top: 30px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 14px 22px;
    background: #1f1f1f;
    color: white;
    text-decoration: none;
    border-radius: 999px;
  }

  .btn:hover {
    opacity: 0.85;
  }
</style>