---
import MainLayout from "../layouts/MainLayout.astro";
import { galleryItems } from "../data/gallery";
import "../styles/gallery.css";
---

<MainLayout title="Galerie">
  <section class="gallery-page">

    <h1>Galerie</h1>

    <!-- Suche -->
    <input
      type="text"
      placeholder="Suche..."
      class="search"
      id="searchInput"
    />

    <!-- Kategorien -->
    <div class="filters">
      <button type="button" data-category="Alle" class="active">Alle</button>
      <button type="button" data-category="Ostern">Ostern</button>
      <button type="button" data-category="Dekoration">Dekoration</button>
      <button type="button" data-category="Badezimmer">Badezimmer</button>
      <button type="button" data-category="Schmuck">Schmuck</button>
      <button type="button" data-category="Geschenkkarten">Geschenkkarten</button>
    </div>

    <!-- Grid -->
    <div class="grid" id="galleryGrid">
      {galleryItems.map(item => (
        <div
          class="card"
          data-category={item.category}
          data-title={item.title.toLowerCase()}
        >
          <img src={item.image} alt={item.title} />
          <div class="overlay">
            <p>{item.title}</p>
          </div>
        </div>
      ))}
    </div>

    <dialog id="lightbox" class="lightbox">
      <button id="lightbox-close" class="lightbox-close" type="button" aria-label="Schließen">x</button>

      <!-- Pfeile -->
      <button id="prev-btn" class="nav-btn left">‹</button>
      <button id="next-btn" class="nav-btn right">›</button>

      <img id="lightbox-img" src="" alt="" />
    </dialog>

  </section>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      const buttons = document.querySelectorAll(".filters button");
      const cards = document.querySelectorAll(".card");
      const searchInput = document.getElementById("searchInput");

      let currentCategory = "Alle";

      function filterItems() {
        const searchValue = searchInput ? searchInput.value.toLowerCase() : "";

        cards.forEach((card) => {
          const title = card.dataset.title || "";
          const category = card.dataset.category || "";

          const matchesSearch = title.includes(searchValue);
          const matchesCategory =
            currentCategory === "Alle" || category === currentCategory;

          card.style.display = matchesSearch && matchesCategory ? "" : "none";
        });
      }

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          buttons.forEach((b) => b.classList.remove("active"));
          btn.classList.add("active");
          currentCategory = btn.dataset.category || "Alle";
          filterItems();
        });
      });

      if (searchInput) {
        searchInput.addEventListener("input", filterItems);
      }

      filterItems();
    });
  </script>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      const lightbox = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightbox-img");
      const closeButton = document.getElementById("lightbox-close");
      const prevBtn = document.getElementById("prev-btn");
      const nextBtn = document.getElementById("next-btn");

      let visibleImages = [];
      let currentIndex = 0;

      function getVisibleImages() {
        return Array.from(document.querySelectorAll(".card"))
          .filter((card) => getComputedStyle(card).display !== "none")
          .map((card) => card.querySelector("img"))
          .filter(Boolean);
      }

      function openImage(index) {
        visibleImages = getVisibleImages();
        if (!visibleImages.length) return;

        currentIndex = index;
        const currentImg = visibleImages[currentIndex];

        if (lightbox && lightboxImg && currentImg) {
          lightboxImg.src = currentImg.src;
          lightboxImg.alt = currentImg.alt;
          if (!lightbox.open) {
            lightbox.showModal();
          }
        }
      }

      function showNext() {
        visibleImages = getVisibleImages();
        if (!visibleImages.length) return;

        currentIndex = (currentIndex + 1) % visibleImages.length;
        openImage(currentIndex);
      }

      function showPrev() {
        visibleImages = getVisibleImages();
        if (!visibleImages.length) return;

        currentIndex = (currentIndex - 1 + visibleImages.length) % visibleImages.length;
        openImage(currentIndex);
      }

      function bindImageClicks() {
        const visibleCards = Array.from(document.querySelectorAll(".card"))
          .filter((card) => getComputedStyle(card).display !== "none");

        visibleCards.forEach((card, index) => {
          const img = card.querySelector("img");
          if (!img) return;

          img.onclick = () => {
            visibleImages = visibleCards
              .map((c) => c.querySelector("img"))
              .filter(Boolean);

            openImage(index);
          };
        });
      }

      bindImageClicks();

      const observer = new MutationObserver(() => {
        bindImageClicks();
      });

      document.querySelectorAll(".card").forEach((card) => {
        observer.observe(card, {
          attributes: true,
          attributeFilter: ["style", "class"],
        });
      });

      if (closeButton && lightbox) {
        closeButton.addEventListener("click", () => {
          lightbox.close();
        });
      }

      if (prevBtn) {
        prevBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          showPrev();
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          showNext();
        });
      }

      if (lightbox) {
        lightbox.addEventListener("click", (e) => {
          const rect = lightbox.getBoundingClientRect();
          const clickedInside =
            e.clientX >= rect.left &&
            e.clientX <= rect.right &&
            e.clientY >= rect.top &&
            e.clientY <= rect.bottom;

          if (!clickedInside) {
            lightbox.close();
          }
        });

        document.addEventListener("keydown", (e) => {
          if (!lightbox.open) return;

          if (e.key === "Escape") {
            lightbox.close();
          } else if (e.key === "ArrowRight") {
            showNext();
          } else if (e.key === "ArrowLeft") {
            showPrev();
          }
        });
      }
    });
  </script>
</MainLayout>

