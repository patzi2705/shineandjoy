---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const { title = "ShineAndJoy" } = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <style>
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #3d4245;
        color: white;
        text-align: center;
      }

      main {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 120px 20px 80px;
        box-sizing: border-box;
      }

      h1 {
        font-size: 3rem;
        letter-spacing: 2px;
      }

      p {
        margin-top: 20px;
        color: #ccc;
      }
    </style>
  </head>

  <body>
    <Header />

    <main>
      <div>
        <h1>DIESE SEITE<br />BEFINDET SICH<br />IM AUFBAU.</h1>
        <p>THIS SITE IS UNDER CONSTRUCTION.</p>
      </div>
    </main>

    <Footer />
  </body>
</html>